{
	"name": "obsidian-auto-headings",
	"version": "0.3.12",
	"description": "自动为 Markdown 文件中的标题编号，支持完全自定义的多模板与按路径配置。首版仅提供中文界面。",
	"main": "main.js",
	"type": "module",
	"scripts": {
		"dev": "node esbuild.config.mjs",
		"build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
		"release": "npm run build && node scripts/sync-release.mjs",
		"test": "vitest run",
		"test:watch": "vitest",
		"lint": "eslint . --ext .ts",
		"format": "prettier --write .",
		"format:check": "prettier --check ."
	},
	"keywords": [
		"obsidian",
		"obsidian-plugin",
		"headings",
		"numbering"
	],
	"author": "AArlert",
	"license": "MIT",
	"devDependencies": {
		"@types/node": "22.10.2",
		"@typescript-eslint/eslint-plugin": "8.18.0",
		"@typescript-eslint/parser": "8.18.0",
		"adm-zip": "^0.5.17",
		"builtin-modules": "3.3.0",
		"esbuild": "0.28.1",
		"eslint": "8.57.1",
		"obsidian": "1.7.2",
		"prettier": "3.3.3",
		"tslib": "2.8.1",
		"typescript": "5.6.3",
		"vitest": "3.2.6"
	}
}
